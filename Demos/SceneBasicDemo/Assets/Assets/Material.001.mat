{
    "Shader": "exampleShader",
    "Rasterization": {
        "CullMode": "Back",
        "PolygonMode": "Fill",
        "Primitive": "Triangles"
    },
    "DepthStencil": {
        "DepthWrite": true,
        "DepthFunction": "LessOrEqual",
        "StencilTestEnable": false,
        "FrontStencil": {
            "FailOp": "Keep",
            "PassOp": "Keep",
            "DepthFailOp": "Keep",
            "CompareOp": "Always"
        },
        "BackStencil": {
            "FailOp": "Keep",
            "PassOp": "Keep",
            "DepthFailOp": "Keep",
            "CompareOp": "Always"
        }
    },
    "BlendState": {
        "Enable": false,
        "SrcColor": "One",
        "DstColor": "Zero",
        "ColorOp": "Add",
        "SrcAlpha": "One",
        "DstAlpha": "Zero",
        "AlphaOp": "Add",
        "WriteMask": "All"
    },
    "Resources": [
        {
            "type": "Engine.GameResources.TextureResource",
            "external": true,
            "path": "spot_texture"
        }
    ],
    "Arguments": {
        "Texture": {
            "type": "Engine.Core.GameResourceReference",
            "value": 0
        }
    }
}